{
  "name": "petc-desktop",
  "version": "0.1.0",
  "description": "PETC Desktop — Electron + Python sidecar for emission testing centers",
  "private": true,
  "main": "electron/dist/main.js",
  "scripts": {
    "dev": "concurrently \"npm run dev:renderer\" \"npm run dev:electron\"",
    "dev:renderer": "cd renderer && npm run dev",
    "dev:electron": "tsc -p electron/tsconfig.json --watch",
    "build": "npm run build:renderer && npm run build:electron",
    "build:renderer": "cd renderer && npm run build",
    "build:electron": "tsc -p electron/tsconfig.json",
    "electron": "electron .",
    "pack": "electron-builder --config installer/electron-builder.yml --dir",
    "dist": "electron-builder --config installer/electron-builder.yml"
  },
  "dependencies": {
    "electron-log": "^5.2.0",
    "electron-updater": "^6.3.9"
  },
  "devDependencies": {
    "concurrently": "^9.0.1",
    "electron": "^32.2.0",
    "electron-builder": "^25.1.8",
    "typescript": "^5.6.3",
    "@types/node": "^22.7.6"
  }
}
